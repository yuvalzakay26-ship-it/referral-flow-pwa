# ---------------------------------------------------------------------------
# ReferralFlow environment variables
# Copy this file to `.env.local` and fill in the values.
# The app runs fully in MOCK MODE when the Supabase vars are missing.
#
# ReferralFlow is an ADMIN-ONLY private CRM. There is no public interface
# other than the admin login screen.
# ---------------------------------------------------------------------------

# App URL (used for metadata / absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default WhatsApp updates channel (shown privately in settings)
NEXT_PUBLIC_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/your-channel-id

# Default WhatsApp number in international format, digits only (no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000

# ---- Supabase (leave blank to stay in mock mode) --------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key — NEVER expose to the client / commit a real value
SUPABASE_SERVICE_ROLE_KEY=

# The single authorized administrator's email (auth allow-list / admin_users)
ADMIN_EMAIL=admin@example.com

# Force mock data even if Supabase vars are set ("true" / "false").
# The prominent mock-mode warning disappears only when this is "false" AND
# valid Supabase env vars are provided.
NEXT_PUBLIC_USE_MOCK_DATA=true
