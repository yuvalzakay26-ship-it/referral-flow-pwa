# ---------------------------------------------------------------------------
# ReferralFlow environment variables
# Copy this file to `.env.local` and fill in the values.
#
# ReferralFlow is an OWNER-ONLY private CRM. There is no public interface other
# than the admin login screen. Production MUST use Supabase (not mock mode).
# ---------------------------------------------------------------------------

# App URL (used for metadata / absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default WhatsApp updates channel (shown privately in settings)
NEXT_PUBLIC_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/your-channel-id

# Default WhatsApp number in international format, digits only (no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000

# ---- Supabase -------------------------------------------------------------
# Public project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe key. Prefer the modern publishable key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon key is supported as a fallback if you don't have a publishable key.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Data mode ------------------------------------------------------------
# "true" forces the in-memory mock (local development only). PRODUCTION MUST be
# "false" AND provide the Supabase vars above — the app fails closed otherwise
# and never silently falls back to mock data in production.
NEXT_PUBLIC_USE_MOCK_DATA=false

# Notes:
# - The single owner account is created manually in Supabase Authentication and
#   authorized via supabase/bootstrap_owner.sql (see README). There is no signup.
# - Never place a service-role key in NEXT_PUBLIC_* or in browser code. This app
#   does not require a service-role key at runtime.
