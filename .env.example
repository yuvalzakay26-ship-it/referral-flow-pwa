# ---------------------------------------------------------------------------
# ReferralFlow environment variables
# Copy this file to `.env.local` and fill in the values.
# The app runs fully in MOCK MODE when Supabase vars are missing.
# ---------------------------------------------------------------------------

# Public site URL (used for metadata / absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp updates channel (shown on the success screen and settings)
NEXT_PUBLIC_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/your-channel-id

# Default WhatsApp number in international format, digits only (no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000

# ---- Supabase (leave blank to stay in mock mode) --------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key — NEVER expose to the client / commit a real value
SUPABASE_SERVICE_ROLE_KEY=

# Admin email used for the initial admin_users row / auth allow-list
ADMIN_EMAIL=admin@example.com

# Force mock data even if Supabase vars are set ("true" / "false")
NEXT_PUBLIC_USE_MOCK_DATA=true
